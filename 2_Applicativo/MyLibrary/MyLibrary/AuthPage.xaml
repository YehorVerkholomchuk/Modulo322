<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyLibrary.AuthPage">

    <Grid WidthRequest="950"
          HeightRequest="550"
          HorizontalOptions="Center"
          VerticalOptions="Center"
          ColumnDefinitions="*, *"
          ColumnSpacing="40"
          Padding="20">

        <!-- Pannello Login -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="40">
            <VerticalStackLayout Spacing="25" VerticalOptions="Center">

                <VerticalStackLayout Spacing="4">
                    <Label Text="Login" FontSize="26" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#111111, Dark=White}"/>
                    <Label Text="Accedi al tuo profilo MyLibrary."
                           Style="{StaticResource LabelSubtitle}"/>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Username" Style="{StaticResource LabelFieldTitle}"/>
                    <Entry x:Name="LoginUser" Placeholder="Username" HeightRequest="45"/>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Password" Style="{StaticResource LabelFieldTitle}"/>
                    <Entry x:Name="LoginPass" IsPassword="True" Placeholder="••••••••" HeightRequest="45"/>
                </VerticalStackLayout>

                <Button Text="Accedi"
                        Style="{StaticResource ButtonPrimary}"
                        Clicked="OnLoginAttemptClick"
                        Margin="0,10,0,0"/>
            </VerticalStackLayout>
        </Border>

        <!-- Pannello Registrazione -->
        <Border Grid.Column="1" Style="{StaticResource Card}" Padding="40">
            <VerticalStackLayout Spacing="25" VerticalOptions="Center">

                <VerticalStackLayout Spacing="4">
                    <Label Text="Registrati" FontSize="26" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#111111, Dark=White}"/>
                    <Label Text="Crea un nuovo account MyLibrary."
                           Style="{StaticResource LabelSubtitle}"/>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Username" Style="{StaticResource LabelFieldTitle}"/>
                    <Entry x:Name="RegisterUser" Placeholder="Username" HeightRequest="45"/>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Password" Style="{StaticResource LabelFieldTitle}"/>
                    <Entry x:Name="RegisterPass" IsPassword="True" Placeholder="••••••••" HeightRequest="45"/>
                </VerticalStackLayout>

                <Button Text="Crea account"
                        Style="{StaticResource ButtonPrimary}"
                        Clicked="OnRegisterAttemptClick"
                        Margin="0,10,0,0"/>
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>
