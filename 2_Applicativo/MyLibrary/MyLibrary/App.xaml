<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MyLibrary"
             x:Class="MyLibrary.App">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Font globale: modificabile a runtime dalle Settings -->
            <x:String x:Key="GlobalFontFamily">OpenSansRegular</x:String>
            <x:Double x:Key="GlobalFontSize">14</x:Double>
        </ResourceDictionary>
    </Application.Resources>

</Application>