<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyLibrary.MainPage">

    <Grid ColumnDefinitions="240, *">
        <!-- Sidebar -->
        <Border Grid.Column="0" BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#1A1A1A}" StrokeThickness="0">
            <Grid RowDefinitions="Auto, *, Auto" Padding="24,36,24,28">

                <!-- Logo / App Name -->
                <VerticalStackLayout Grid.Row="0" Spacing="4" Margin="0,0,0,40">
                    <Label Text="MY LIBRARY"
                           TextColor="{AppThemeBinding Light=#111111, Dark=White}"
                           FontSize="13"
                           FontAttributes="Bold"
                           CharacterSpacing="3"/>
                    <BoxView HeightRequest="1" BackgroundColor="#2E2E2E" Margin="0,10,0,0"/>
                </VerticalStackLayout>

                <!-- Nav Items -->
                <VerticalStackLayout Grid.Row="1" Spacing="4">
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Dashboard" TextColor="{AppThemeBinding Light=#111111, Dark=White}" FontSize="16" />
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Add Media"
                               TextColor="#6B6B6B"
                               FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToAddMedia"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Statistics"
                               TextColor="#6B6B6B"
                               FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToStats"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Profile"
                               TextColor="#6B6B6B"
                               FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToProfile"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Settings"
                               TextColor="#6B6B6B"
                               FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToSettings"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="About"
                               TextColor="#6B6B6B"
                               FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToAbout"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" RowDefinitions="Auto, Auto, *" Padding="40,0,40,40" RowSpacing="28">

            <!-- Header Row -->
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" VerticalOptions="Center">
                <VerticalStackLayout Grid.Column="0" Spacing="5">
                    <Label Text="Dashboard"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#111111, Dark=White}"/>
                    <Label Text="Track, review, and organize books, movies, or sagas locally."
                           FontSize="13"
                           TextColor="#9A9A8E"/>
                </VerticalStackLayout>

                <Border Grid.Column="1"
                        WidthRequest="300"
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="#FFFFFF"
                        StrokeThickness="1"
                        Stroke="#E4E2DC"
                        VerticalOptions="Center">
                    <SearchBar x:Name="MediaSearchBar"
                               Placeholder="Search your items..."
                               BackgroundColor="Transparent"
                               TextColor="#111111"
                               PlaceholderColor="#BBBBAA"
                               TextChanged="OnSearchTextChanged"/>
                </Border>
            </Grid>

            <!-- Stats Row -->
            <Grid Grid.Row="1" ColumnDefinitions="*, *, *" ColumnSpacing="16">

                <Border Grid.Column="0"
                        BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="1"
                        Stroke="#EDEBE4"
                        Padding="22,18">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="TOTAL MEDIA"
                               TextColor="#AAAAAA"
                               FontSize="10"
                               FontAttributes="Bold"
                               CharacterSpacing="2"/>
                        <Label x:Name="lblTotalCount"
                               Text="0"
                               FontSize="34"
                               FontAttributes="Bold"
                               TextColor="#111111"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="1"
                        Stroke="#EDEBE4"
                        Padding="22,18">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="COMPLETED"
                               TextColor="#AAAAAA"
                               FontSize="10"
                               FontAttributes="Bold"
                               CharacterSpacing="2"/>
                        <Label x:Name="lblCompletedCount"
                               Text="0"
                               FontSize="34"
                               FontAttributes="Bold"
                               TextColor="#111111"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="2"
                        BackgroundColor="#FFFFFF"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="1"
                        Stroke="#EDEBE4"
                        Padding="22,18">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="TIME TRACKED"
                               TextColor="#AAAAAA"
                               FontSize="10"
                               FontAttributes="Bold"
                               CharacterSpacing="2"/>
                        <Label x:Name="lblTotalHours"
                               Text="0 hrs"
                               FontSize="34"
                               FontAttributes="Bold"
                               TextColor="#111111"/>
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- Media Table -->
            <Border Grid.Row="2"
                    BackgroundColor="#FFFFFF"
                    StrokeShape="RoundRectangle 14"
                    StrokeThickness="1"
                    Stroke="#EDEBE4"
                    Padding="28,24">
                <Grid RowDefinitions="Auto, Auto, *" RowSpacing="0">

                    <!-- Table Header Label -->
                    <Label Grid.Row="0"
                           Text="Media Collection"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="#111111"
                           Margin="0,0,0,16"/>

                    <!-- Column Headers -->
                    <Grid Grid.Row="1"
                          ColumnDefinitions="*, Auto, Auto, Auto"
                          Padding="15,0"
                          Margin="0,0,0,8">
                        <Label Grid.Column="0" Text="TITLE" TextColor="#AAAAAA" FontSize="10" FontAttributes="Bold" CharacterSpacing="2"/>
                        <Label Grid.Column="1" Text="TYPE"  TextColor="#AAAAAA" FontSize="10" FontAttributes="Bold" CharacterSpacing="2" Margin="20,0"/>
                        <Label Grid.Column="2" Text="GENRE" TextColor="#AAAAAA" FontSize="10" FontAttributes="Bold" CharacterSpacing="2" Margin="20,0"/>
                        <Label Grid.Column="3" Text="RATING" TextColor="#AAAAAA" FontSize="10" FontAttributes="Bold" CharacterSpacing="2" Margin="20,0"/>
                    </Grid>

                    <!-- Items List -->
                    <CollectionView Grid.Row="2"
                                    x:Name="MediaCollectionView"
                                    SelectionMode="Single"
                                    SelectionChanged="OnMediaSelectionChanged">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="4"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeShape="RoundRectangle 8"
                                        StrokeThickness="1"
                                        Stroke="#F3F1EB"
                                        Padding="15,14"
                                        BackgroundColor="#FAFAF8">
                                    <Grid ColumnDefinitions="*, Auto, Auto, Auto">
                                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                                            <Label Text="{Binding Title}"
                                                   FontAttributes="Bold"
                                                   FontSize="14"
                                                   TextColor="#111111"/>
                                            <Label Text="{Binding ConnectedSaga}"
                                                   FontSize="11"
                                                   TextColor="#BBBBAA"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1"
                                               Text="{Binding Type}"
                                               VerticalOptions="Center"
                                               TextColor="#777777"
                                               FontSize="13"
                                               Margin="20,0"/>
                                        <Label Grid.Column="2"
                                               Text="{Binding Genre}"
                                               VerticalOptions="Center"
                                               TextColor="#777777"
                                               FontSize="13"
                                               Margin="20,0"/>
                                        <Label Grid.Column="3"
                                               Text="{Binding Rating}"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center"
                                               TextColor="#C9A84C"
                                               FontSize="13"
                                               Margin="20,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
