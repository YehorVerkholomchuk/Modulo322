<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyLibrary.MainPage">

    <Grid ColumnDefinitions="240, *">

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Column="0" Style="{StaticResource SidebarBorder}">
            <Grid RowDefinitions="Auto, *, Auto" Padding="24,36,24,28">

                <VerticalStackLayout Grid.Row="0" Spacing="4" Margin="0,0,0,40">
                    <Label Text="MY LIBRARY" FontSize="13" FontAttributes="Bold"
                           CharacterSpacing="3"
                           TextColor="{AppThemeBinding Light=#111111, Dark=White}"/>
                    <BoxView Style="{StaticResource Divider}"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="1" Spacing="4">
                    <!-- Pagina attiva: Dashboard -->
                    <Border Style="{StaticResource NavItemBorder}">
                        <Label Text="Dashboard" Style="{StaticResource NavLabelActive}"/>
                    </Border>

                    <Border Style="{StaticResource NavItemBorder}">
                        <Label Text="Add Media" Style="{StaticResource NavLabelInactive}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToAddMedia"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border Style="{StaticResource NavItemBorder}">
                        <Label Text="Statistics" Style="{StaticResource NavLabelInactive}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToStats"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border Style="{StaticResource NavItemBorder}">
                        <Label Text="Profile" Style="{StaticResource NavLabelInactive}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToProfile"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border Style="{StaticResource NavItemBorder}">
                        <Label Text="Settings" Style="{StaticResource NavLabelInactive}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToSettings"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border Style="{StaticResource NavItemBorder}">
                        <Label Text="About" Style="{StaticResource NavLabelInactive}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToAbout"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </VerticalStackLayout>

            </Grid>
        </Border>

        <!-- ===== CONTENUTO PRINCIPALE ===== -->
        <Grid Grid.Column="1" RowDefinitions="Auto, Auto, *" Padding="40,0,40,40" RowSpacing="28">

            <!-- Header con titolo e barra di ricerca -->
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" VerticalOptions="Center">
                <VerticalStackLayout Grid.Column="0" Spacing="5">
                    <Label Text="Dashboard" FontSize="28" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#111111, Dark=White}"/>
                    <Label Text="Cerca, filtra e gestisci la tua collezione."
                           Style="{StaticResource LabelSubtitle}"/>
                </VerticalStackLayout>

                <Border Grid.Column="1" WidthRequest="300"
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                        StrokeThickness="1"
                        Stroke="#E4E2DC"
                        VerticalOptions="Center">
                    <SearchBar x:Name="MediaSearchBar"
                               Placeholder="Cerca nella libreria..."
                               BackgroundColor="Transparent"
                               TextChanged="OnSearchTextChanged"/>
                </Border>
            </Grid>

            <!-- Contatori riassuntivi -->
            <Grid Grid.Row="1" ColumnDefinitions="*, *, *" ColumnSpacing="16">

                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="22,18">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="MEDIA TOTALI" Style="{StaticResource LabelTableHeader}"/>
                        <Label x:Name="lblTotalCount" Text="0" Style="{StaticResource LabelCounter}"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}" Padding="22,18">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="COMPLETATI" Style="{StaticResource LabelTableHeader}"/>
                        <Label x:Name="lblCompletedCount" Text="0" Style="{StaticResource LabelCounter}"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="22,18">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="ORE TRACCIATE" Style="{StaticResource LabelTableHeader}"/>
                        <Label x:Name="lblTotalHours" Text="0 hrs" Style="{StaticResource LabelCounter}"/>
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- Tabella media -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="28,24">
                <Grid RowDefinitions="Auto, Auto, *" RowSpacing="0">

                    <Label Grid.Row="0" Text="Collezione Media"
                           FontSize="15" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#111111, Dark=White}"
                           Margin="0,0,0,16"/>

                    <!-- Intestazioni colonne -->
                    <Grid Grid.Row="1" ColumnDefinitions="*, Auto, Auto, Auto" Padding="15,0" Margin="0,0,0,8">
                        <Label Grid.Column="0" Text="TITOLO" Style="{StaticResource LabelTableHeader}"/>
                        <Label Grid.Column="1" Text="TIPO"   Style="{StaticResource LabelTableHeader}" Margin="20,0"/>
                        <Label Grid.Column="2" Text="GENERE" Style="{StaticResource LabelTableHeader}" Margin="20,0"/>
                        <Label Grid.Column="3" Text="VOTO"   Style="{StaticResource LabelTableHeader}" Margin="20,0"/>
                    </Grid>

                    <!-- Lista elementi -->
                    <CollectionView Grid.Row="2"
                                    x:Name="MediaCollectionView"
                                    SelectionMode="Single"
                                    SelectionChanged="OnMediaSelectionChanged">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="4"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeShape="RoundRectangle 8"
                                        StrokeThickness="1"
                                        Stroke="#F3F1EB"
                                        Padding="15,14"
                                        BackgroundColor="{AppThemeBinding Light=#FAFAF8, Dark=#252525}">
                                    <Grid ColumnDefinitions="*, Auto, Auto, Auto">
                                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="14"
                                                   TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"/>
                                            <Label Text="{Binding ConnectedSaga}" FontSize="11" TextColor="#BBBBAA"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1" Text="{Binding Type}"
                                               VerticalOptions="Center" TextColor="#777777" FontSize="13" Margin="20,0"/>
                                        <Label Grid.Column="2" Text="{Binding Genre}"
                                               VerticalOptions="Center" TextColor="#777777" FontSize="13" Margin="20,0"/>
                                        <Label Grid.Column="3" Text="{Binding Rating}"
                                               FontAttributes="Bold" VerticalOptions="Center"
                                               TextColor="#C9A84C" FontSize="13" Margin="20,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </Grid>
            </Border>

        </Grid>
    </Grid>
</ContentPage>
