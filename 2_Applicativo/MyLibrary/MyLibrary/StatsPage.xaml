<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyLibrary.StatsPage"
             Title="StatsPage">

    <Grid ColumnDefinitions="240, *">
        <!-- Sidebar -->
        <Border Grid.Column="0" BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#1A1A1A}" StrokeThickness="0">
            <Grid RowDefinitions="Auto, *, Auto" Padding="24,36,24,28">

                <!-- Logo / App Name -->
                <VerticalStackLayout Grid.Row="0" Spacing="4" Margin="0,0,0,40">
                    <Label Text="MY LIBRARY"
                       TextColor="{AppThemeBinding Light=#111111, Dark=White}"
                       FontSize="13"
                       FontAttributes="Bold"
                       CharacterSpacing="3"/>
                    <BoxView HeightRequest="1" BackgroundColor="#2E2E2E" Margin="0,10,0,0"/>
                </VerticalStackLayout>

                <!-- Nav Items -->
                <VerticalStackLayout Grid.Row="1" Spacing="4">
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Dashboard"
                               TextColor="#6B6B6B"
                               FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToDashboard"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Add Media"
                           TextColor="#6B6B6B"
                           FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToAddMedia"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Statistics" TextColor="{AppThemeBinding Light=#111111, Dark=White}" FontSize="16" />
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Profile"
                           TextColor="#6B6B6B"
                           FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToProfile"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Settings"
                           TextColor="#6B6B6B"
                           FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToSettings"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="About"
                           TextColor="#6B6B6B"
                           FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToAbout"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <Grid Grid.Column="1" HorizontalOptions="Fill" Padding="40,0,40,40" RowDefinitions="Auto, Auto, *" RowSpacing="30">
            <VerticalStackLayout Grid.Row="0">
                <Label Text="Statistics" FontSize="28" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111111, Dark=White}"/>
                <Label Text="A summary overview of your collection distributions, completion rates, and time tracked." FontSize="14" TextColor="#9A9A8E"/>
            </VerticalStackLayout>

            <Grid Grid.Row="1" ColumnDefinitions="*, *, *, *" ColumnSpacing="16">
                <Border Grid.Column="0" BackgroundColor="#FFFFFF" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#EDEBE4" Padding="20">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Total Books" TextColor="#AAAAAA" FontSize="10" FontAttributes="Bold" CharacterSpacing="2"/>
                        <Label x:Name="lblTotalBooks" Text="0" FontSize="32" FontAttributes="Bold" TextColor="#111111"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" BackgroundColor="#FFFFFF" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#EDEBE4" Padding="20">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Total Movies" TextColor="#AAAAAA" FontSize="10" FontAttributes="Bold" CharacterSpacing="2"/>
                        <Label x:Name="lblTotalMovies" Text="0" FontSize="32" FontAttributes="Bold" TextColor="#111111"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="2" BackgroundColor="#FFFFFF" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#EDEBE4" Padding="20">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Average Rating" TextColor="#AAAAAA" FontSize="10" FontAttributes="Bold" CharacterSpacing="2"/>
                        <Label x:Name="lblAvgRating" Text="0" FontSize="32" FontAttributes="Bold" TextColor="#C9A84C"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="3" BackgroundColor="#FFFFFF" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#EDEBE4" Padding="20">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Completion Rate" TextColor="#AAAAAA" FontSize="10" FontAttributes="Bold" CharacterSpacing="2"/>
                        <Label x:Name="lblCompletionRate" Text="0%" FontSize="32" FontAttributes="Bold" TextColor="#111111"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="30">

                <Border Grid.Column="0" BackgroundColor="#FFFFFF" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#EDEBE4" Padding="25">
                    <Grid RowDefinitions="Auto, *">
                        <Label Grid.Row="0" Text="Genre Distribution Ledger" FontSize="18" FontAttributes="Bold" TextColor="#111111" Margin="0,0,0,15"/>
                        <ListView Grid.Row="1" x:Name="GenreListView" SelectionMode="None" HasUnevenRows="True" BackgroundColor="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <ViewCell>
                                        <Grid ColumnDefinitions="*, Auto" Padding="10, 8" Margin="0,2">
                                            <Label Grid.Column="0" Text="{Binding Key}" FontSize="15" TextColor="#111111" VerticalOptions="Center"/>
                                            <Border Grid.Column="1" BackgroundColor="#FAFAF8" StrokeShape="RoundRectangle 6" StrokeThickness="1" Stroke="#EDEBE4" Padding="10, 4" HorizontalOptions="End" VerticalOptions="Center">
                                                <Label Text="{Binding Value, StringFormat='{0} items'}" FontSize="12" FontAttributes="Bold" TextColor="#777777"/>
                                            </Border>
                                        </Grid>
                                    </ViewCell>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <Border Grid.Column="1" BackgroundColor="#FFFFFF" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#EDEBE4" Padding="25">
                    <Grid RowDefinitions="Auto, *">
                        <Label Grid.Row="0" Text="Highest Time-Invested Media" FontSize="18" FontAttributes="Bold" TextColor="#111111" Margin="0,0,0,15"/>
                        <CollectionView Grid.Row="1" x:Name="TopTimeCollectionView">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="8"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*, Auto" Padding="10, 8">
                                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="14" TextColor="#111111"/>
                                            <Label Text="{Binding Type}" FontSize="12" TextColor="#BBBBAA"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1" Text="{Binding TimeSpentMinutes, StringFormat='{0} mins'}" FontAttributes="Bold" TextColor="#777777" VerticalOptions="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>