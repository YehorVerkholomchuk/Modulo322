<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyLibrary.ProfilePage"
             Title="ProfilePage">

    <Grid ColumnDefinitions="240, *">
        <!-- Sidebar -->
        <Border Grid.Column="0" BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#1A1A1A}" StrokeThickness="0">
            <Grid RowDefinitions="Auto, *, Auto" Padding="24,36,24,28">

                <!-- Logo / App Name -->
                <VerticalStackLayout Grid.Row="0" Spacing="4" Margin="0,0,0,40">
                    <Label Text="MY LIBRARY"
                   TextColor="{AppThemeBinding Light=#111111, Dark=White}"
                   FontSize="13"
                   FontAttributes="Bold"
                   CharacterSpacing="3"/>
                    <BoxView HeightRequest="1" BackgroundColor="#2E2E2E" Margin="0,10,0,0"/>
                </VerticalStackLayout>

                <!-- Nav Items -->
                <VerticalStackLayout Grid.Row="1" Spacing="4">
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Dashboard"
                                TextColor="#6B6B6B"
                                FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToDashboard"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Add Media"
                       TextColor="#6B6B6B"
                       FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToAddMedia"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Statistics"
                       TextColor="#6B6B6B"
                       FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToStats"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Profile" TextColor="{AppThemeBinding Light=#111111, Dark=White}" FontSize="16"/>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Settings"
                       TextColor="#6B6B6B"
                       FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToSettings"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="About"
                       TextColor="#6B6B6B"
                       FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToAbout"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Column="1" HorizontalOptions="Fill" Padding="40,0,40,40">
            <VerticalStackLayout Spacing="0">
                <Grid ColumnDefinitions="*, *" Margin="0,0,0,20" HorizontalOptions="Fill">
                    <VerticalStackLayout Grid.Column="0" Spacing="5">
                        <Label Text="Profile" FontSize="28" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111111, Dark=White}"/>
                        <Label Text="Manage your identity, tracked media, and personal notes." FontSize="14" TextColor="#9A9A8E" Margin="0,0,0,20"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="10" HorizontalOptions="End">
                        <Button Text="Logout" BackgroundColor="#b00900" TextColor="{AppThemeBinding Light=#111111, Dark=White}" FontAttributes="Bold" Clicked="OnLogoutClicked" HeightRequest="45" WidthRequest="200" />
                        <Button Text="Delete profile" BackgroundColor="#b00900" TextColor="{AppThemeBinding Light=#111111, Dark=White}" FontAttributes="Bold" Clicked="OnDeleteProfileClicked" HeightRequest="45" WidthRequest="200" />
                    </VerticalStackLayout>
                </Grid>
                
                <Border BackgroundColor="White" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#EDEBE4" Padding="40">
                    <VerticalStackLayout Spacing="20">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Username *" TextColor="#777777" FontAttributes="Bold" FontSize="14"/>
                            <Entry x:Name="EntryUsername" BackgroundColor="#FAFAF8" TextColor="#111111"/>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Location" TextColor="#777777" FontAttributes="Bold" FontSize="14"/>
                                <Entry x:Name="EntryLocation" Placeholder="New York, USA" BackgroundColor="#FAFAF8" TextColor="#111111"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="Creation Date" TextColor="#777777" FontAttributes="Bold" FontSize="14"/>
                                <DatePicker x:Name="PickerCreationDate" IsEnabled="False" BackgroundColor="#FAFAF8" TextColor="#111111"/>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#EDEBE4" Margin="0,10,0,10"/>

                        <Label Text="Media Tracked (From Logs)" FontSize="24" FontAttributes="Bold" TextColor="#111111" Margin="0,0,0,10"/>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Movies Watched" TextColor="#777777" FontAttributes="Bold" FontSize="14"/>
                                <Entry x:Name="EntryMovies" Placeholder="0" IsReadOnly="True" BackgroundColor="#FAFAF8" TextColor="#111111"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="Books Read" TextColor="#777777" FontAttributes="Bold" FontSize="14"/>
                                <Entry x:Name="EntryBooks" Placeholder="0" IsReadOnly="True" BackgroundColor="#FAFAF8" TextColor="#111111"/>
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="TV Series Watched" TextColor="#777777" FontAttributes="Bold" FontSize="14"/>
                                <Entry x:Name="EntryTV" Placeholder="0" IsReadOnly="True" BackgroundColor="#FAFAF8" TextColor="#111111"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="Anime Watched" TextColor="#777777" FontAttributes="Bold" FontSize="14"/>
                                <Entry x:Name="EntryAnime" Placeholder="0" IsReadOnly="True" BackgroundColor="#FAFAF8" TextColor="#111111"/>
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Comics Read" TextColor="#777777" FontAttributes="Bold" FontSize="14"/>
                            <Entry x:Name="EntryComics" Placeholder="0" IsReadOnly="True" BackgroundColor="#FAFAF8" TextColor="#111111"/>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" BackgroundColor="#EDEBE4" Margin="0,10,0,10"/>

                        <Label Text="Personal Notes" FontSize="24" FontAttributes="Bold" TextColor="#111111" Margin="0,0,0,10"/>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Favorite Media" TextColor="#777777" FontAttributes="Bold" FontSize="14"/>
                            <Editor x:Name="EditorFavorites" Placeholder="No favorites added yet..." IsReadOnly="True" HeightRequest="90" BackgroundColor="#FAFAF8" TextColor="#111111"/>
                        </VerticalStackLayout>

                        <Button Text="Save Profile" BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#1A1A1A}" TextColor="{AppThemeBinding Light=#111111, Dark=White}" FontAttributes="Bold" Clicked="OnSaveProfileClicked" HeightRequest="45" Margin="0,20,0,0"/>

                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>