<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyLibrary.SettingsPage">

    <Grid ColumnDefinitions="240, *">

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Column="0" Style="{StaticResource SidebarBorder}">
            <Grid RowDefinitions="Auto, *, Auto" Padding="24,36,24,28">

                <VerticalStackLayout Grid.Row="0" Spacing="4" Margin="0,0,0,40">
                    <Label Text="MY LIBRARY" FontSize="13" FontAttributes="Bold"
                           CharacterSpacing="3"
                           TextColor="{AppThemeBinding Light=#111111, Dark=White}"/>
                    <BoxView Style="{StaticResource Divider}"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="1" Spacing="4">

                    <Border Style="{StaticResource NavItemBorder}">
                        <Label Text="Dashboard" Style="{StaticResource NavLabelInactive}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToDashboard"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border Style="{StaticResource NavItemBorder}">
                        <Label Text="Add Media" Style="{StaticResource NavLabelInactive}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToAddMedia"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border Style="{StaticResource NavItemBorder}">
                        <Label Text="Statistics" Style="{StaticResource NavLabelInactive}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToStats"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border Style="{StaticResource NavItemBorder}">
                        <Label Text="Profile" Style="{StaticResource NavLabelInactive}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToProfile"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <!-- Pagina attiva: Settings -->
                    <Border Style="{StaticResource NavItemBorder}">
                        <Label Text="Settings" Style="{StaticResource NavLabelActive}"/>
                    </Border>

                    <Border Style="{StaticResource NavItemBorder}">
                        <Label Text="About" Style="{StaticResource NavLabelInactive}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToAbout"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- ===== CONTENUTO PRINCIPALE ===== -->
        <ScrollView Grid.Column="1" Padding="40,0,40,40" HorizontalOptions="Fill">
            <Grid RowDefinitions="Auto, *" RowSpacing="30">

                <!-- Header con titolo e pulsante salva -->
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="5" VerticalOptions="Center">
                        <Label Text="Impostazioni" FontSize="28" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#111111, Dark=White}"/>
                        <Label Text="Personalizza aspetto, tipografia e accessibilità."
                               Style="{StaticResource LabelSubtitle}"/>
                    </VerticalStackLayout>

                    <Button Grid.Column="1"
                            Text="Salva configurazione"
                            Style="{StaticResource ButtonPrimary}"
                            WidthRequest="200"
                            Clicked="OnSaveSettingsClicked"/>
                </Grid>

                <!-- Griglia 2x2 delle sezioni impostazioni -->
                <Grid Grid.Row="1"
                      ColumnDefinitions="*, *"
                      RowDefinitions="Auto, Auto"
                      ColumnSpacing="25"
                      RowSpacing="25">

                    <!-- ASPETTO -->
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="15">

                            <Label Text="Aspetto" Style="{StaticResource LabelSectionTitle}"/>
                            <BoxView Style="{StaticResource Divider}"/>

                            <Label Text="Tema colori" Style="{StaticResource LabelFieldTitle}"/>
                            <Picker x:Name="PickerTheme">
                                <Picker.Items>
                                    <x:String>Light</x:String>
                                    <x:String>Dark</x:String>
                                    <x:String>System Default</x:String>
                                </Picker.Items>
                            </Picker>

                            <Grid ColumnDefinitions="*, Auto" Margin="0,10,0,0">
                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                    <Label Text="Alto contrasto" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"/>
                                    <Label Text="Migliora la leggibilità per utenti con difficoltà visive."
                                           FontSize="12" Style="{StaticResource LabelSubtitle}"/>
                                </VerticalStackLayout>
                                <Switch Grid.Column="1" x:Name="SwitchHighContrast" Style="{StaticResource SettingsSwitch}"/>
                            </Grid>

                        </VerticalStackLayout>
                    </Border>

                    <!-- TIPOGRAFIA -->
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="15">

                            <Label Text="Tipografia" Style="{StaticResource LabelSectionTitle}"/>
                            <BoxView Style="{StaticResource Divider}"/>

                            <Label Text="Famiglia di font" Style="{StaticResource LabelFieldTitle}"/>
                            <Picker x:Name="PickerFont">
                                <Picker.Items>
                                    <x:String>Default (Open Sans)</x:String>
                                    <x:String>Serif (Times New Roman)</x:String>
                                    <x:String>Monospace (Consolas)</x:String>
                                    <x:String>Dyslexic Friendly</x:String>
                                </Picker.Items>
                            </Picker>

                            <Label x:Name="LblFontSizeDisplay" Text="Dimensione testo: 14"
                                   Style="{StaticResource LabelFieldTitle}" Margin="0,10,0,0"/>
                            <Slider x:Name="SliderFontSize"
                                    Minimum="10" Maximum="24" Value="14"
                                    MinimumTrackColor="#1A1A1A"
                                    MaximumTrackColor="#EDEBE4"
                                    ValueChanged="OnFontSizeChanged"/>

                        </VerticalStackLayout>
                    </Border>

                    <!-- ACCESSIBILITÀ -->
                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="15">

                            <Label Text="Accessibilità" Style="{StaticResource LabelSectionTitle}"/>
                            <BoxView Style="{StaticResource Divider}"/>

                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                    <Label Text="Screen reader" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"/>
                                    <Label Text="Abilita descrizioni verbose per Narrator."
                                           FontSize="12" Style="{StaticResource LabelSubtitle}"/>
                                </VerticalStackLayout>
                                <Switch Grid.Column="1" x:Name="SwitchScreenReader" Style="{StaticResource SettingsSwitch}"/>
                            </Grid>

                        </VerticalStackLayout>
                    </Border>

                    <!-- GENERALI -->
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="15">

                            <Label Text="Generali" Style="{StaticResource LabelSectionTitle}"/>
                            <BoxView Style="{StaticResource Divider}"/>

                            <Label Text="Lingua" Style="{StaticResource LabelFieldTitle}"/>
                            <Picker x:Name="PickerLanguage">
                                <Picker.Items>
                                    <x:String>English</x:String>
                                    <x:String>Italiano</x:String>
                                    <x:String>Deutsch</x:String>
                                    <x:String>Français</x:String>
                                </Picker.Items>
                            </Picker>

                            <Grid ColumnDefinitions="*, Auto" Margin="0,10,0,0">
                                <Label Grid.Column="0" Text="Notifiche app"
                                       FontAttributes="Bold" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"/>
                                <Switch Grid.Column="1" x:Name="SwitchNotifications" Style="{StaticResource SettingsSwitch}"/>
                            </Grid>

                        </VerticalStackLayout>
                    </Border>

                </Grid>
            </Grid>
        </ScrollView>

    </Grid>
</ContentPage>
