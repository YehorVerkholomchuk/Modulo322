<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyLibrary.SettingsPage"
             Title="SettingsPage">

    <Grid ColumnDefinitions="240, *">
        <!-- Sidebar -->
        <Border Grid.Column="0" BackgroundColor="Transparent" StrokeThickness="0">
            <Grid RowDefinitions="Auto, *, Auto" Padding="24,36,24,28">

                <!-- Logo / App Name -->
                <VerticalStackLayout Grid.Row="0" Spacing="4" Margin="0,0,0,40">
                    <Label Text="MY LIBRARY"
                   TextColor="{AppThemeBinding Light=#111111, Dark=White}"
                   FontSize="13"
                   FontAttributes="Bold"
                   CharacterSpacing="3"/>
                    <BoxView HeightRequest="1" BackgroundColor="#2E2E2E" Margin="0,10,0,0"/>
                </VerticalStackLayout>

                <!-- Nav Items -->
                <VerticalStackLayout Grid.Row="1" Spacing="4">
                    <Border Style="{StaticResource LeftSelectorItem}">
                        <Label Text="Dashboard"
                                Style="{StaticResource LeftSelectorLbl}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToDashboard"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border Style="{StaticResource LeftSelectorItem}">
                        <Label Text="Add Media"
                       Style="{StaticResource LeftSelectorLbl}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToAddMedia"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border Style="{StaticResource LeftSelectorItem}">
                        <Label Text="Statistics"
                       Style="{StaticResource LeftSelectorLbl}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToStats"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border Style="{StaticResource LeftSelectorItem}">
                        <Label Text="Profile"
                       Style="{StaticResource LeftSelectorLbl}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToProfile"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border Style="{StaticResource LeftSelectorItem}">
                        <Label Text="Settings" Style="{StaticResource LeftSelectorLblActive}"/>
                    </Border>

                    <Border Style="{StaticResource LeftSelectorItem}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNavigateToAbout"/>
                        </Border.GestureRecognizers>

                        <Label Text="About"
           Style="{StaticResource LeftSelectorLbl}" />
                    </Border>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Column="1" Padding="40,0,40,40" HorizontalOptions="Fill">
            <Grid RowDefinitions="Auto, *" RowSpacing="30">

                <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="5" VerticalOptions="Center">
                        <Label Text="Settings" FontSize="28" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111111, Dark=White}" SemanticProperties.HeadingLevel="Level1"/>
                        <Label Text="Customize your interface, typography, and accessibility features." FontSize="14" TextColor="#777777"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="Save Configuration" BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#1A1A1A}" TextColor="{AppThemeBinding Light=#111111, Dark=White}" FontAttributes="Bold" Clicked="OnSaveSettingsClicked" HeightRequest="45" WidthRequest="200" SemanticProperties.Hint="Saves all currently selected settings to your profile."/>
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" ColumnSpacing="25" RowSpacing="25">

                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardSettings}">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="Appearance" Style="{StaticResource CardSettingsName}"/>
                            <BoxView HeightRequest="1" Style="{StaticResource CardSettingsBox}"/>

                            <Label Text="Color Theme" TextColor="#777777" FontAttributes="Bold" FontSize="14"/>
                            <Picker x:Name="PickerTheme" Style="{StaticResource CardSettingsPicker}" SemanticProperties.Description="Select Application Theme">
                                <Picker.Items>
                                    <x:String>Light</x:String>
                                    <x:String>Dark</x:String>
                                    <x:String>System Default</x:String>
                                </Picker.Items>
                            </Picker>

                            <Grid ColumnDefinitions="*, Auto" Margin="0,10,0,0">
                                <Label Grid.Column="0" Text="High Contrast Mode" VerticalOptions="Center" TextColor="#111111" FontAttributes="Bold" SemanticProperties.Description="Enable high contrast for visually impaired users."/>
                                <Switch Grid.Column="1" x:Name="SwitchHighContrast" OnColor="#1A1A1A"/>
                            </Grid>
                            <Label Text="Increases border visibility and text legibility." FontSize="12" TextColor="#9A9A8E"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardSettings}">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="Typography" Style="{StaticResource CardSettingsName}"/>
                            <BoxView HeightRequest="1" Style="{StaticResource CardSettingsBox}"/>

                            <Label Text="Font Family" TextColor="#777777" FontAttributes="Bold" FontSize="14"/>
                            <Picker x:Name="PickerFont" SemanticProperties.Description="Select Font Family" Style="{StaticResource CardSettingsPicker}">
                                <Picker.Items>
                                    <x:String>Default (Open Sans)</x:String>
                                    <x:String>Serif (Times New Roman)</x:String>
                                    <x:String>Monospace (Consolas)</x:String>
                                    <x:String>Dyslexic Friendly</x:String>
                                </Picker.Items>
                            </Picker>

                            <Label x:Name="LblFontSizeDisplay" Text="Global Font Size: 14" TextColor="#777777" FontAttributes="Bold" FontSize="14" Margin="0,10,0,0"/>
                            <Slider x:Name="SliderFontSize" Minimum="10" Maximum="24" Value="14" MinimumTrackColor="#1A1A1A" MaximumTrackColor="#EDEBE4" ValueChanged="OnFontSizeChanged" SemanticProperties.Description="Adjust text size."/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardSettings}">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="Accessibility" Style="{StaticResource CardSettingsName}"/>
                            <BoxView HeightRequest="1" Style="{StaticResource CardSettingsBox}"/>

                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                    <Label Text="Screen Reader Enhancements" TextColor="#111111" FontAttributes="Bold"/>
                                    <Label Text="Enables verbose UI descriptions for Narrator." FontSize="12" TextColor="#9A9A8E"/>
                                </VerticalStackLayout>
                                <Switch Grid.Column="1" x:Name="SwitchScreenReader" OnColor="#1A1A1A" VerticalOptions="Center"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardSettings}">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="General" Style="{StaticResource CardSettingsName}"/>
                            <BoxView HeightRequest="1" Style="{StaticResource CardSettingsBox}"/>

                            <Label Text="Language" Style="{StaticResource CardSettingsName}"/>
                            <Picker x:Name="PickerLanguage" Style="{StaticResource CardSettingsPicker}">
                                <Picker.Items>
                                    <x:String>English</x:String>
                                    <x:String>Italiano</x:String>
                                    <x:String>Deutsch</x:String>
                                    <x:String>Français</x:String>
                                </Picker.Items>
                            </Picker>

                            <Grid ColumnDefinitions="*, Auto" Margin="0,10,0,0">
                                <Label Grid.Column="0" Text="App Notifications" VerticalOptions="Center" TextColor="#111111" FontAttributes="Bold"/>
                                <Switch Grid.Column="1" x:Name="SwitchNotifications" OnColor="#1A1A1A" VerticalOptions="Center"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>