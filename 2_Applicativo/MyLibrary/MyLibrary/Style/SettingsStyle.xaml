<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyLibrary.Style.SettingsStyle">

    <Style x:Key="CardSettings" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=Transparent, Dark=Transparent}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="Padding" Value="25" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light=#EDEBE4, Dark=#676767}" />
    </Style>
    
    <Style x:Key="CardSettingsName" TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="CardSettingsBox" TargetType="BoxView">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#111111, Dark=#676767}" />
        <Setter Property="Margin" Value="0,-5,0,5" />
    </Style>
    
    <Style x:Key="CardSettingsPicker" TargetType="Picker">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#111111, Dark=#333}" />
        <Setter Property="TextColor" Value="#FFFFFF" />
    </Style>
</ResourceDictionary>