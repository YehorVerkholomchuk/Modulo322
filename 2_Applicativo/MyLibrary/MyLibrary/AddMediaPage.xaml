<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyLibrary.AddMediaPage"
             Title="Add Media">

    <Grid ColumnDefinitions="240, *">
        <!-- Sidebar -->
        <Border Grid.Column="0" BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#1A1A1A}" StrokeThickness="0">
            <Grid RowDefinitions="Auto, *, Auto" Padding="24,36,24,28">

                <!-- Logo / App Name -->
                <VerticalStackLayout Grid.Row="0" Spacing="4" Margin="0,0,0,40">
                    <Label Text="MY LIBRARY"
                       TextColor="{AppThemeBinding Light=#111111, Dark=White}"
                       FontSize="13"
                       FontAttributes="Bold"
                       CharacterSpacing="3"/>
                    <BoxView HeightRequest="1" BackgroundColor="#2E2E2E" Margin="0,10,0,0"/>
                </VerticalStackLayout>

                <!-- Nav Items -->
                <VerticalStackLayout Grid.Row="1" Spacing="4">
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Dashboard"
                           TextColor="#6B6B6B"
                           FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToDashboard"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Add Media" TextColor="{AppThemeBinding Light=#111111, Dark=White}" FontSize="16" />
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Statistics"
                           TextColor="#6B6B6B"
                           FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToStats"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Profile"
                           TextColor="#6B6B6B"
                           FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToProfile"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Settings"
                           TextColor="#6B6B6B"
                           FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToSettings"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="About"
                           TextColor="#6B6B6B"
                           FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToAbout"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Column="1" HorizontalOptions="Fill" Padding="40,0,40,40">
            <VerticalStackLayout Spacing="0">
                <Label Text="Add Media" FontSize="28" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111111, Dark=White}"/>
                <Label Text="A form for adding new media to your collection" FontSize="14" TextColor="#9A9A8E" Margin="0,0,0,20"/>
                <Border BackgroundColor="White" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#EDEBE4" Padding="40">
                    <VerticalStackLayout Spacing="20">

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Title *" TextColor="#777777" FontAttributes="Bold" FontSize="14"/>
                            <Entry x:Name="EntryTitle" Placeholder="Enter media title..." BackgroundColor="#FAFAF8" TextColor="#111111"/>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*, *, *, *" ColumnSpacing="15">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Media Type *" TextColor="#777777" FontAttributes="Bold" FontSize="14"/>
                                <Picker x:Name="PickerType" BackgroundColor="#FAFAF8" TextColor="#111111">
                                    <Picker.ItemsSource>
                                        <x:Array Type="{x:Type x:String}">
                                            <x:String>Movie</x:String>
                                            <x:String>TV Series</x:String>
                                            <x:String>Anime</x:String>
                                            <x:String>Book</x:String>
                                            <x:String>Comic</x:String>
                                        </x:Array>
                                    </Picker.ItemsSource>
                                </Picker>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="Genre" TextColor="#777777" FontAttributes="Bold" FontSize="14"/>
                                <Entry x:Name="EntryGenre" Placeholder="Sci-Fi, Fantasy..." BackgroundColor="#FAFAF8" TextColor="#111111"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="2" Spacing="5">
                                <Label Text="Rating" TextColor="#777777" FontAttributes="Bold" FontSize="14"/>
                                <Picker x:Name="PickerRating" BackgroundColor="#FAFAF8" TextColor="#111111">
                                    <Picker.ItemsSource>
                                        <x:Array Type="{x:Type x:Int32}">
                                            <x:Int32>1</x:Int32>
                                            <x:Int32>2</x:Int32>
                                            <x:Int32>3</x:Int32>
                                            <x:Int32>4</x:Int32>
                                            <x:Int32>5</x:Int32>
                                            <x:Int32>6</x:Int32>
                                            <x:Int32>7</x:Int32>
                                            <x:Int32>8</x:Int32>
                                            <x:Int32>9</x:Int32>
                                            <x:Int32>10</x:Int32>
                                        </x:Array>
                                    </Picker.ItemsSource>
                                </Picker>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="3" Spacing="5">
                                <Label Text="Time Spent (Minutes)" TextColor="#777777" FontAttributes="Bold" FontSize="14"/>
                                <Entry x:Name="EntryTime" Placeholder="120..." Keyboard="Numeric" BackgroundColor="#FAFAF8" TextColor="#111111"/>
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Personal Review" TextColor="#777777" FontAttributes="Bold" FontSize="14"/>
                            <Editor x:Name="EditorReview" Placeholder="Write your opinion here..." BackgroundColor="#FAFAF8" TextColor="#111111"/>
                        </VerticalStackLayout>

                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                            <CheckBox x:Name="CheckCompleted" Color="#C9A84C"/>
                            <Label Text="Mark as Completed" VerticalOptions="Center" TextColor="#777777" FontSize="14"/>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                            <CheckBox x:Name="CheckFavorite" Color="#C9A84C"/>
                            <Label Text="To Favourites" VerticalOptions="Center" TextColor="#777777" FontSize="14"/>
                        </HorizontalStackLayout>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,20,0,0">
                            <Button Grid.Column="0" Text="Cancel" BackgroundColor="#EDEBE4" TextColor="#777777" Clicked="OnCancelClicked"/>
                            <Button Grid.Column="1" Text="Save Item" BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#1A1A1A}" TextColor="{AppThemeBinding Light=#111111, Dark=White}" FontAttributes="Bold" Clicked="OnSaveClicked"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>