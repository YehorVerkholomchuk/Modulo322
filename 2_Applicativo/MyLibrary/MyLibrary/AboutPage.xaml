<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyLibrary.AboutPage"
             Title="AboutPage">
    <Grid ColumnDefinitions="240, *">
        <!-- Sidebar -->
        <Border Grid.Column="0" BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#1A1A1A}" StrokeThickness="0">
            <Grid RowDefinitions="Auto, *, Auto" Padding="24,36,24,28">

                <!-- Logo / App Name -->
                <VerticalStackLayout Grid.Row="0" Spacing="4" Margin="0,0,0,40">
                    <Label Text="MY LIBRARY"
                   TextColor="{AppThemeBinding Light=#111111, Dark=White}"
                   FontSize="13"
                   FontAttributes="Bold"
                   CharacterSpacing="3"/>
                    <BoxView HeightRequest="1" BackgroundColor="#2E2E2E" Margin="0,10,0,0"/>
                </VerticalStackLayout>

                <!-- Nav Items -->
                <VerticalStackLayout Grid.Row="1" Spacing="4">
                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Dashboard"
                                TextColor="#6B6B6B"
                                FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToDashboard"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Add Media"
                       TextColor="#6B6B6B"
                       FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToAddMedia"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Statistics"
                       TextColor="#6B6B6B"
                       FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToStats"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Profile"
                       TextColor="#6B6B6B"
                       FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToProfile"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="Settings"
                       TextColor="#6B6B6B"
                       FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNavigateToSettings"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Border BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="14,12">
                        <Label Text="About" TextColor="{AppThemeBinding Light=#111111, Dark=White}" FontSize="16" />
                    </Border>
                    
                </VerticalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Column="1" Padding="40,0,40,40" HorizontalOptions="Fill">
            <VerticalStackLayout Spacing="30">

                <VerticalStackLayout Spacing="5">
                    <Label Text="About" FontSize="28" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"/>
                    <Label Text="Your personal, privacy-first media tracking catalog." FontSize="14" TextColor="{AppThemeBinding Light=#64748B, Dark=#9A9A8E}"/>
                </VerticalStackLayout>

                <Border BackgroundColor="{AppThemeBinding Light=#262626, Dark=#FFFFFF}" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#333333}" Padding="25">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Overview" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#FFFFFF, Dark=#111111}"/>
                        <Label Text="MyLibrary is a desktop-optimized management system designed to help users track their books, movies, anime, and other media. Built with a focus on local storage and multi-user privacy, it allows you to log progress, write reviews, and visualize your entertainment habits without relying on cloud services." 
                               LineHeight="1.5" TextColor="{AppThemeBinding Light=#CCCCCC, Dark=#555}"/>
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto" ColumnSpacing="20" RowSpacing="20">
                    <Border Grid.Row="0" Grid.Column="0" BackgroundColor="{AppThemeBinding Light=#262626, Dark=#FFFFFF}" StrokeShape="RoundRectangle 8" StrokeThickness="1" Padding="15">
                        <VerticalStackLayout>
                            <Label Text="Dashboard" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#FFFFFF, Dark=#111111}"/>
                            <Label Text="Your main hub. View, search, and filter your entire media collection." FontSize="12" TextColor="{AppThemeBinding Light=#CCCCCC, Dark=#555}"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="1" BackgroundColor="{AppThemeBinding Light=#262626, Dark=#FFFFFF}" StrokeShape="RoundRectangle 8" StrokeThickness="1" Padding="15">
                        <VerticalStackLayout>
                            <Label Text="Add Media" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#FFFFFF, Dark=#111111}"/>
                            <Label Text="The input engine to log new items, ratings, and review notes." FontSize="12" TextColor="{AppThemeBinding Light=#CCC, Dark=#555}"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="0" BackgroundColor="{AppThemeBinding Light=#262626, Dark=#FFFFFF}" StrokeShape="RoundRectangle 8" StrokeThickness="1" Padding="15">
                        <VerticalStackLayout>
                            <Label Text="Statistics" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#FFFFFF, Dark=#111111}"/>
                            <Label Text="Visual analytics calculating your time spent, completion rates, and favorite genres." FontSize="12" TextColor="{AppThemeBinding Light=#CCC, Dark=#555}"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" BackgroundColor="{AppThemeBinding Light=#262626, Dark=#FFFFFF}" StrokeShape="RoundRectangle 8" StrokeThickness="1" Padding="15">
                        <VerticalStackLayout>
                            <Label Text="Profile" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#FFFFFF, Dark=#111111}"/>
                            <Label Text="Manage your identity, view specific goals, and handle account deletion/logout." FontSize="12" TextColor="{AppThemeBinding Light=#CCC, Dark=#555}"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="0" BackgroundColor="{AppThemeBinding Light=#262626, Dark=#FFFFFF}" StrokeShape="RoundRectangle 8" StrokeThickness="1" Padding="15">
                        <VerticalStackLayout>
                            <Label Text="Settings" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#FFFFFF, Dark=#111111}"/>
                            <Label Text="Customize typography, color themes, and accessibility modes." FontSize="12" TextColor="{AppThemeBinding Light=#CCC, Dark=#555}"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="1" BackgroundColor="{AppThemeBinding Light=#262626, Dark=#FFFFFF}" StrokeShape="RoundRectangle 8" StrokeThickness="1" Padding="15">
                        <VerticalStackLayout>
                            <Label Text="About" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#FFFFFF, Dark=#111111}"/>
                            <Label Text="Well, you are here!" FontSize="12" TextColor="{AppThemeBinding Light=#CCC, Dark=#555}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="20">

                    <Border Grid.Column="0" BackgroundColor="{AppThemeBinding Light=#262626, Dark=#FFFFFF}" StrokeShape="RoundRectangle 12" StrokeThickness="1" Padding="25">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Details" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#FFFFFF, Dark=#111111}"/>

                            <Grid ColumnDefinitions="110, *" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="Project:" TextColor="{AppThemeBinding Light=#FFF, Dark=#555}" FontAttributes="Bold"/>
                                <Label Grid.Column="1" Text="MyLibrary" TextColor="{AppThemeBinding Light=#111111, Dark=#555}"/>
                            </Grid>
                            <Grid ColumnDefinitions="110, *" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="Authors:" TextColor="{AppThemeBinding Light=#FFF, Dark=#555}" FontAttributes="Bold"/>
                                <Label Grid.Column="1" Text="Riccardo Grosa, Fabio Maruca, Yehor Verkholomchuk" TextColor="{AppThemeBinding Light=#FFF, Dark=#555}"/>
                            </Grid>
                            <Grid ColumnDefinitions="110, *" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="Date:" TextColor="{AppThemeBinding Light=#FFF, Dark=#555}" FontAttributes="Bold"/>
                                <Label Grid.Column="1" Text="30.05.2026" TextColor="{AppThemeBinding Light=#FFF, Dark=#555}"/>
                            </Grid>
                            <Grid ColumnDefinitions="110, *" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="Framework:" TextColor="{AppThemeBinding Light=#FFF, Dark=#555}" FontAttributes="Bold"/>
                                <Label Grid.Column="1" Text=".NET MAUI (C# / XAML)" TextColor="{AppThemeBinding Light=#FFF, Dark=#555}"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" BackgroundColor="{AppThemeBinding Light=#262626, Dark=#FFF}" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#333333}" Padding="25">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Contacts" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#FFF, Dark=#111}"/>

                            <Label Text="For technical support or questions, contact us:" TextColor="{AppThemeBinding Light=#FFF, Dark=#555}" LineHeight="1.3"/>

                            <Label Text="cde@edu.ti.ch" TextColor="#0078D4" FontAttributes="Bold" TextDecorations="Underline" Margin="0,0,0,0"/>
                            <Label Text="fabio@edu.ti.ch" TextColor="#0078D4" FontAttributes="Bold" TextDecorations="Underline" Margin="0,0,0,0"/>
                            <Label Text="grosa@edu.ti.ch" TextColor="#0078D4" FontAttributes="Bold" TextDecorations="Underline" Margin="0,0,0,5"/>

                            <Label Text="© 2026 MyLibrary" FontSize="12" TextColor="{AppThemeBinding Light=#FFF, Dark=#555}"/>
                        </VerticalStackLayout>
                    </Border>

                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>