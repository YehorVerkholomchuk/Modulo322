<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyLibrary.FilmPage"
             Title="FilmPage" BackgroundColor="#001F3D">
    <Grid RowDefinitions="Auto,*,Auto"
          Padding="20">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto"
              Margin="0,10,0,20">

            <!-- Left Buttons -->
            <HorizontalStackLayout
                Spacing="14"
                VerticalOptions="Center">

                <!-- Menu -->
                <Frame
                    WidthRequest="40"
                    HeightRequest="40"
                    CornerRadius="20"
                    Padding="0"
                    BackgroundColor="#ED985F"
                    HasShadow="False">
                </Frame>

                <!-- Books -->
                <Frame
                    WidthRequest="40"
                    HeightRequest="40"
                    CornerRadius="20"
                    Padding="0"
                    BackgroundColor="#ED985F"
                    HasShadow="False">
                </Frame>

                <!-- Movies -->
                <Frame
                    WidthRequest="40"
                    HeightRequest="40"
                    CornerRadius="20"
                    Padding="0"
                    BackgroundColor="#ED985F"
                    HasShadow="False">

                    <Image
                        Source="movie.png"
                        WidthRequest="20"
                        HeightRequest="20"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                </Frame>
            </HorizontalStackLayout>

            <!-- Search -->
            <Frame
                Grid.Column="1"
                Margin="40,0"
                WidthRequest="400"
                HeightRequest="42"
                CornerRadius="20"
                BackgroundColor="White"
                BorderColor="#ED985F"
                Padding="15,0"
                HasShadow="False">

                <SearchBar
                    Placeholder="Search a movie or a book..."
                    BackgroundColor="Transparent"
                    CancelButtonColor="Transparent"
                    VerticalOptions="Center" />
            </Frame>

            <!-- Profile -->
            <Frame
                Grid.Column="2"
                WidthRequest="40"
                HeightRequest="40"
                CornerRadius="20"
                Padding="0"
                BackgroundColor="#ED985F"
                HasShadow="False"
                HorizontalOptions="End">

                <Image
                    Source="profile.png"
                    WidthRequest="22"
                    HeightRequest="22"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
            </Frame>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1"
              ColumnDefinitions="2*,3*"
              ColumnSpacing="30">

            <!-- LEFT FEATURED -->
            <Frame
                Grid.Column="0"
                BackgroundColor="#ED985F"
                CornerRadius="8"
                Padding="0"
                Margin="60,0,0,0"
                HasShadow="False">

                <Grid>

                    <Label
                        Text="Recent Books&#10;&amp; News"
                        FontSize="26"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        HorizontalTextAlignment="Center"
                        TextColor="#001F3D" />

                    <!-- Carousel Indicators -->
                    <HorizontalStackLayout
                        Spacing="10"
                        HorizontalOptions="Center"
                        VerticalOptions="End"
                        Margin="0,0,0,18">

                        <BoxView WidthRequest="40"
                                 HeightRequest="3"
                                 Color="#ED985F" />

                        <BoxView WidthRequest="40"
                                 HeightRequest="3"
                                 Color="#ED985F" />

                        <BoxView WidthRequest="40"
                                 HeightRequest="3"
                                 Color="#ED985F" />

                        <BoxView WidthRequest="40"
                                 HeightRequest="3"
                                 Color="#ED985F" />
                    </HorizontalStackLayout>
                </Grid>
            </Frame>

            <!-- RIGHT GRID -->
            <Grid
                Grid.Column="1"
                RowDefinitions="*,*,*,Auto"
                ColumnDefinitions="*,*,*,*"
                RowSpacing="40"
                ColumnSpacing="60">

                <!-- BOOK ITEMS -->
                <!-- Row 1 -->
                <CollectionView
                    Grid.RowSpan="3"
                    Grid.ColumnSpan="4"
                    HorizontalOptions="Center">

                    <CollectionView.ItemsLayout>
                        <GridItemsLayout
                            Orientation="Vertical"
                            Span="4"
                            HorizontalItemSpacing="0"
                            VerticalItemSpacing="10"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>1</x:String>
                            <x:String>2</x:String>
                            <x:String>3</x:String>
                            <x:String>4</x:String>
                            <x:String>5</x:String>
                            <x:String>6</x:String>
                            <x:String>7</x:String>
                            <x:String>8</x:String>
                            <x:String>9</x:String>
                            <x:String>10</x:String>
                            <x:String>11</x:String>
                            <x:String>12</x:String>
                        </x:Array>
                    </CollectionView.ItemsSource>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>

                            <Frame HeightRequest="250"
                                   WidthRequest="200"
                                   BackgroundColor="#ED985F"
                                   CornerRadius="6"
                                   Padding="10"
                                   HasShadow="False">

                                <Label Text="Book&#10;Poster"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#001F3D" />
                            </Frame>

                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Pagination -->
                <HorizontalStackLayout
                    Grid.Row="3"
                    Grid.ColumnSpan="4"
                    HorizontalOptions="Center"
                    Margin="0,20,0,0"
                    Spacing="8">

                    <Label TextColor="White" Text="1" />
                    <Label TextColor="White" Text="2" />
                    <Label TextColor="White" Text="3" />
                    <Label TextColor="White" Text="..." />
                    <Label TextColor="White" Text="500" />
                </HorizontalStackLayout>
            </Grid>
        </Grid>

        <!-- FOOTER -->
        <HorizontalStackLayout
            Grid.Row="2"
            Margin="0,25,0,0"
            Spacing="30">

            <Label TextColor="White" Text="About" FontSize="14" />
            <Label TextColor="White" Text="Settings" FontSize="14" />
            <Label TextColor="White" Text="Contact" FontSize="14" />
            <Label TextColor="White" Text="Help" FontSize="14" />
            <Label TextColor="White" Text="FAQ" FontSize="14" />
        </HorizontalStackLayout>
    </Grid>
</ContentPage>