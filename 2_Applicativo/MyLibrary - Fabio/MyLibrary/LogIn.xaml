<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyLibrary.MainPage">

    <ScrollView>
        <Grid Padding="30"
              VerticalOptions="Center"
              HorizontalOptions="Fill"
              MaximumWidthRequest="1200">

            <!-- Contenitore principale -->
            <Frame BackgroundColor="#62c1e5"
                   CornerRadius="16"
                   Padding="30"
                   HasShadow="True">

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="40"
                      RowDefinitions="Auto">

                    <!-- ===== COLONNA SINISTRA ===== -->
                    <VerticalStackLayout Grid.Column="0"
                                         Spacing="24"
                                         VerticalOptions="Center"
                                         Margin="50,20,0,20">

                        <!-- Titolo + Sottotitolo -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Sign in"
                                   FontSize="52"
                                   FontAttributes="Bold"
                                   TextColor="#EDE8E0"/>
                            <Label Text="Create your account"
                                   FontSize="22"
                                   TextColor="#a09890"/>
                        </VerticalStackLayout>

                        <!-- Card Form -->
                        <Frame BackgroundColor="#a0d9ef"
                               CornerRadius="12"

                               Padding="24"
                               HasShadow="True"
                               MaximumWidthRequest="320"
                               HorizontalOptions="Start">

                            <VerticalStackLayout Spacing="12">

                                <Label Text="Create your account"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#1A1A1A"/>

                                <!-- Campo Username -->
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Username"
                                           FontSize="14"
                                           TextColor="#333333"/>

                                    <Entry x:Name="entUsername"
                                               Placeholder="PulcinoPio"
                                               PlaceholderColor="#000000"
                                               BackgroundColor="#cfecf7"
                                               TextColor="#EDE8E0"
                                               FontSize="14"
                                               Margin="8,4"/>
                                </VerticalStackLayout>

                                <!-- Campo Mail -->
                                <VerticalStackLayout Spacing="4"
                                                      Margin="0,8,0,0">
                                    <Label Text="Mail"
                                           FontSize="14"
                                           TextColor="#333333"/>
                                    <Entry x:Name="entMail"
                                               Placeholder="mail@gmail.com"
                                               PlaceholderColor="#000000"
                                               BackgroundColor="#cfecf7"
                                               TextColor="#EDE8E0"
                                               Keyboard="Email"
                                               FontSize="14"
                                               Margin="8,4"/>
                                </VerticalStackLayout>

                                <!-- Bottone Continue Clicked="OnContinueClicked"-->
                                <Button Text="Continue"
                                        x:Name="continueBtn"
                                        TextColor="#EDE8E0"
                                        BackgroundColor="#1c96c5"
                                        BorderWidth="1.5"
                                        FontAttributes="Bold"
                                        FontSize="15"
                                        CornerRadius="22"
                                        HeightRequest="44"
                                        WidthRequest="180"
                                        HorizontalOptions="Center"
                                        Margin="0,20,0,0"
                                        />

                            </VerticalStackLayout>
                        </Frame>

                        <!-- Bottone Log in Clicked="OnLoginClicked"-->
                        <Button Text="Log in"
                                x:Name="loginBtn"
                                BackgroundColor="#1c96c5"
                                TextColor="#ffffff"
                                FontAttributes="Bold"
                                FontSize="14"
                                CornerRadius="8"
                                HeightRequest="40"
                                WidthRequest="100"
                                HorizontalOptions="Start"
                                />

                    </VerticalStackLayout>

                    <!-- ===== COLONNA DESTRA - Placeholder immagine ===== -->
                    <Frame Margin="0,0,50,0"
                            Grid.Column="1"
                           BackgroundColor="#a0d9ef"
                           CornerRadius="12"

                           Padding="0"
                           HasShadow="True"
                           HeightRequest="520"
                           HorizontalOptions="Fill"
                           VerticalOptions="Fill">
                        <!-- Sostituisci con:
                             <Image Source="tuaimmagine.png" Aspect="AspectFill"/> -->
                    </Frame>

                </Grid>
            </Frame>
        </Grid>
    </ScrollView>

</ContentPage>