<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyLibrary.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="40, 0"
            Spacing="25"
            WidthRequest="1920"
            HeightRequest="1080">
            <Frame 
            BackgroundColor="#001F3D"
            CornerRadius="10"
            Padding="10"
            HasShadow="True"
            HeightRequest="500">
                <VerticalStackLayout>
                    <Label
                        Text="Sign In"
                        FontFamily=""
                        FontSize="40"
                        FontAttributes="Bold"
                        TextColor="#ED985F"
                        Margin="40, 0, 0, 40"/>

                    <Label
                        Text="Create your account"
                        FontSize="25"
                        TextColor="White"
                        Margin="40, -40, 0, 0"/>
                    <!--Promt: su maui come faccio dei box? -->
                    <Frame 
                    BackgroundColor="#ED985F"
                    CornerRadius="10"
                    Padding="10"
                    Margin="40, 45, 0, 50"
                    HasShadow="True"
                    WidthRequest="250"
                    HeightRequest="300"
                    HorizontalOptions="Start">

                        <VerticalStackLayout>
                            <Label
                            Text="Create your account"
                            TextColor="White"
                            FontSize="20"
                            FontAttributes="Bold"
                            Margin="15, 0, 0, 0"/>
                            
                            <Label
                            Text="Username"
                            FontSize="15"
                            TextColor="White"
                            Margin="30, 20, 0, 0"/>
                            <Entry
                            x:Name="entUsername"
                            BackgroundColor="White"
                            Margin="30, 5, 20, 0"
                            Placeholder="DenisDosio93"/>

                            <Label
                            Text="Mail"
                            FontSize="15"
                            TextColor="White"
                            Margin="30, 20, 0, 0"/>
                            <Entry
                            x:Name="entMail"
                            BackgroundColor="White"
                            Margin="30, 5, 20, 0"
                            Placeholder="Fedez.Nero@gmail.com"/>
                            <Button
                            x:Name="btn"
                            Clicked="OnCounterClicked"
                            Text="FilmPage"/>
                        </VerticalStackLayout>  

                    </Frame>

                </VerticalStackLayout>

            </Frame>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
