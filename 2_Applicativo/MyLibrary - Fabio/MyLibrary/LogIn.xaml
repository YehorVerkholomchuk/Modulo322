<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyLibrary.MainPage">

    <ScrollView>
        <Grid Padding="20">

            <!-- Contenitore principale -->
            <Frame
                BackgroundColor="#969696"
                CornerRadius="10"
                Padding="25"
                HasShadow="True">

                <Grid RowDefinitions="Auto,Auto,*"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="50"
                      RowSpacing="20">

                    <!-- Titolo -->
                    <VerticalStackLayout 
                        Grid.Row="0"
                        Grid.Column="0">

                        <Label
                            Text="Sign In"
                            FontSize="50"
                            FontAttributes="Bold"/>

                        <Label
                            Text="Create your account"
                            FontSize="25"
                            TextColor="#757575"/>
                    </VerticalStackLayout>

                    <!-- Box a destra -->
                    <Frame
                        Grid.Row="0"
                        Grid.Column="1"
                        BackgroundColor="#d9d9d9"
                        CornerRadius="10"
                        BorderColor="Black"
                        Padding="10"
                        HasShadow="True"
                        HeightRequest="300"
                        HorizontalOptions="Fill"/>

                    <!-- Form -->
                    <Frame
                        Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        BackgroundColor="#d9d9d9"
                        CornerRadius="10"
                        BorderColor="Black"
                        Padding="20"
                        HasShadow="True"
                        HorizontalOptions="Start"
                        MaximumWidthRequest="450">

                        <VerticalStackLayout Spacing="10">

                            <Label
                                Text="Create your account"
                                FontSize="20"
                                FontAttributes="Bold"/>

                            <Label
                                Text="Username"
                                FontSize="15"/>

                            <Entry
                                x:Name="entUsername"
                                BackgroundColor="White"
                                Placeholder="PulcinoPio"/>

                            <Label
                                Text="Mail"
                                FontSize="15"
                                Margin="0,10,0,0"/>

                            <Entry
                                x:Name="entMail"
                                BackgroundColor="White"
                                Placeholder="Yehor.Verholomchuck@gmail.com"/>

                            <Button
                                Text="Continue"
                                x:Name="continueBtn"
                                BackgroundColor="#d9d9d9"
                                BorderColor="Black"
                                TextColor="Black"
                                Margin="0,25,0,0"
                                CornerRadius="20"
                                FontAttributes="Bold"
                                BorderWidth="1"
                                HorizontalOptions="Center"
                                WidthRequest="180"/>
                        </VerticalStackLayout>
                    </Frame>

                </Grid>
            </Frame>
        </Grid>
    </ScrollView>

</ContentPage>